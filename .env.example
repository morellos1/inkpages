# Copy to .env and adjust as needed.
DATABASE_URL=postgresql://inkpages:inkpages@localhost:5433/inkpages

# X (Twitter) official pay-per-use API. Never use gray-market scrapers.
X_API_CONSUMER_KEY=
X_API_CONSUMER_SECRET=
X_API_BEARER_TOKEN=

# pixiv logged-in session cookie (PHPSESSID), for R18 rankings
PIXIV_SESSION=
